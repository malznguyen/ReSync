# Compose
COMPOSE_PROJECT_NAME=resync

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vision_system
POSTGRES_USER=vision_user
POSTGRES_PASSWORD=CHANGE_ME_DO_NOT_USE_THIS_IN_PROD

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Ingestion
INGESTION_EXPECTED_FPS=30
INGESTION_FPS_WARNING_THRESHOLD=25
INGESTION_DROP_WARNING_RATE=0.05
INGESTION_FPS_LOG_INTERVAL_SECONDS=10
INGESTION_CAMERA_REFRESH_SECONDS=30
INGESTION_WATCHDOG_POLL_SECONDS=1
INGESTION_WATCHDOG_INITIAL_BACKOFF_SECONDS=1
INGESTION_WATCHDOG_MAX_BACKOFF_SECONDS=5
INGESTION_WATCHDOG_STABLE_SECONDS=30
INGESTION_STREAM_READ_FAILURE_SECONDS=5
INGESTION_REDIS_SOCKET_TIMEOUT_SECONDS=2
INGESTION_JPEG_QUALITY=85
INGESTION_GSTREAMER_ENABLED=true
INGESTION_GSTREAMER_LATENCY_MS=100
LOG_LEVEL=INFO

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=CHANGE_ME
RABBITMQ_MANAGEMENT_PORT=15672

# Adminer
ADMINER_PORT=8080

# API
API_HOST=api
API_PORT=8000
API_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Dashboard
DASHBOARD_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# AI Models (paths inside container)
YOLO_MODEL_PATH=/models/yolov8n-pose.pt
OSNET_MODEL_PATH=/models/osnet_x0_25_msmt17.pth

# AI Worker
AI_WORKER_CAMERA_ID=00000000-0000-0000-0000-000000000101
AI_WORKER_STALE_FRAME_SECONDS=2
AI_WORKER_POLL_SECONDS=0.03
AI_WORKER_FPS_LOG_INTERVAL_SECONDS=10
AI_WORKER_REDIS_SOCKET_TIMEOUT_SECONDS=2
AI_WORKER_YOLO_CONF=0.25
AI_WORKER_YOLO_IOU=0.7
AI_WORKER_YOLO_IMGSZ=640
AI_WORKER_DEVICE=

# Feature flags
REID_ENABLED=true
HAND_RAISE_COOLDOWN_SECONDS=10
SEATED_THRESHOLD_SECONDS=3.0
HAND_RAISE_THRESHOLD_SECONDS=1.5
ZONE_CACHE_REFRESH_SECONDS=60

# MediaMTX
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_HLS_PORT=8888
