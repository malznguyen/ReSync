          "query": [
            {
              "key": "start_at",
              "value": "",
              "disabled": true,
              "description": "Inclusive timestamp start."
            },
            {
              "key": "end_at",
              "value": "",
              "disabled": true,
              "description": "Inclusive timestamp end."
            },
            {
              "key": "zone_id",
              "value": "",
              "disabled": true,
              "description": "Filter by zone ID."
